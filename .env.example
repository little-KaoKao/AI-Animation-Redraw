# RunningHub API Key
RUNNINGHUB_API_KEY=your_api_key_here

# FFmpeg path
# Windows: bin\ffmpeg.exe (download and place in bin/ directory)
# macOS:   ffmpeg (install via: brew install ffmpeg)
# Linux:   ffmpeg (install via: apt install ffmpeg / yum install ffmpeg)
# FFMPEG_PATH=ffmpeg

# Server
HOST=127.0.0.1
PORT=8000

# Data directory
DATA_DIR=./data
